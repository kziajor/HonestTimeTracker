<Window x:Class="HonestTimeTracker.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Honest Time Tracker"
        Icon="pack://application:,,,/app.ico"
        Height="680" Width="1300"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo area -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource PrimaryBrush}"
                        Padding="20,16">
                    <TextBlock Text="Honest Time Tracker"
                               Style="{StaticResource HeaderText}"
                               FontSize="14"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Navigation -->
                <StackPanel x:Name="NavPanel" DockPanel.Dock="Top" Margin="0,8,0,0">
                    <RadioButton Style="{StaticResource NavButton}" Content="Today"    Tag="Today"    GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Projects" Tag="Projects" GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Tasks"    Tag="Tasks"    GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Records"  Tag="Records"  GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Leave"    Tag="Leave"    GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Reports"  Tag="Reports"  GroupName="Nav" Click="NavButton_Click" />
                    <RadioButton Style="{StaticResource NavButton}" Content="Settings" Tag="Settings" GroupName="Nav" Click="NavButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="{StaticResource PrimaryBrush}" />

        <!-- Main content area -->
        <Border Grid.Column="2" Padding="32,28">
            <ContentControl x:Name="MainContent" />
        </Border>
    </Grid>
</Window>
