<Window x:Class="HonestTimeTracker.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Honest Time Tracker"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo area -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource PrimaryBrush}"
                        Padding="20,16">
                    <TextBlock Text="Honest Time Tracker"
                               Style="{StaticResource HeaderText}"
                               FontSize="14"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <Button Style="{StaticResource NavButton}" Content="Dziś" Tag="Today" Click="NavButton_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Projekty" Tag="Projects" Click="NavButton_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Rekordy" Tag="Records" Click="NavButton_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Raporty" Tag="Reports" Click="NavButton_Click" />
                    <Button Style="{StaticResource NavButton}" Content="Ustawienia" Tag="Settings" Click="NavButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="{StaticResource PrimaryBrush}" />

        <!-- Main content area -->
        <Border Grid.Column="2" Padding="32,28">
            <Grid>
                <TextBlock x:Name="PageTitle"
                           Text="Dziś"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Top" />

                <TextBlock Text="Wybierz sekcję z menu bocznego."
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           FontSize="16" />
            </Grid>
        </Border>
    </Grid>
</Window>
