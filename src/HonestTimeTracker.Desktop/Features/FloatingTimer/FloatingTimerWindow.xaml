<Window x:Class="HonestTimeTracker.Desktop.Features.FloatingTimer.FloatingTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Border Background="#FBCB18"
            CornerRadius="8"
            Padding="14,10"
            Cursor="SizeAll"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Opacity="0.4"
                              BlurRadius="14"
                              ShadowDepth="2"
                              Direction="270" />
        </Border.Effect>

        <StackPanel>

            <!-- Task title -->
            <TextBlock Text="{Binding TaskTitle}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Foreground="#000000"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="272"
                       Margin="0,0,0,8" />

            <!-- Spent / Planned -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Spent"
                           FontSize="10"
                           Foreground="#5a3e00"
                           Margin="0,0,0,1" />

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="Planned"
                           FontSize="10"
                           Foreground="#5a3e00"
                           Margin="0,0,0,1" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding TotalSpentText}"
                           FontWeight="Bold"
                           FontSize="15"
                           Foreground="#000000" />

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding PlannedText}"
                           FontWeight="Bold"
                           FontSize="15"
                           Foreground="#000000" />
            </Grid>

            <!-- Progress bar (only when planned > 0) -->
            <StackPanel Margin="0,8,0,0"
                        Visibility="{Binding IsDiffVisible, Converter={StaticResource BoolToVisibility}}">

                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Progress"
                               FontSize="10"
                               Foreground="#5a3e00" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressPercentText}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#000000" />
                </Grid>

                <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                             Minimum="0" Maximum="100"
                             Height="6">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="#1a7a1a" />
                            <Setter Property="Background" Value="#00000022" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3"
                                                Height="{TemplateBinding Height}">
                                            <Border x:Name="PART_Indicator"
                                                    HorizontalAlignment="Left"
                                                    Background="{TemplateBinding Foreground}"
                                                    CornerRadius="3" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOvertime}" Value="True">
                                    <Setter Property="Foreground" Value="#cc0000" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>

            </StackPanel>

            <!-- Diff row -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,6,0,0"
                        Visibility="{Binding IsDiffVisible, Converter={StaticResource BoolToVisibility}}">

                <TextBlock FontSize="11"
                           Foreground="#5a3e00"
                           Text="Diff: " />

                <TextBlock Text="{Binding DiffText}"
                           FontWeight="SemiBold"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Foreground" Value="#1a7a1a" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOvertime}" Value="True">
                                    <Setter Property="Foreground" Value="#cc0000" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#cc0000"
                           Text=" ⚠ overtime"
                           Visibility="{Binding IsOvertime, Converter={StaticResource BoolToVisibility}}" />

            </StackPanel>

        </StackPanel>
    </Border>
</Window>
