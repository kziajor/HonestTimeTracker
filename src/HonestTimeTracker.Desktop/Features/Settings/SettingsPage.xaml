<UserControl x:Class="HonestTimeTracker.Desktop.Features.Settings.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,320,0">

            <TextBlock Text="Settings"
                       Style="{StaticResource HeaderText}"
                       FontSize="18"
                       Margin="0,0,0,24" />

            <!-- Daily work hours -->
            <TextBlock Text="Daily work hours"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Standard number of hours you work per day (used for overtime/deficit reports)."
                       Foreground="#666666"
                       FontSize="12"
                       Margin="0,0,0,8" />
            <TextBox x:Name="DailyWorkHoursBox"
                     Text="{Binding DailyWorkHours, UpdateSourceTrigger=PropertyChanged}"
                     Width="160"
                     HorizontalAlignment="Left"
                     Padding="8,6"
                     FontSize="14"
                     BorderBrush="#CCCCCC"
                     BorderThickness="1"
                     Margin="0,0,0,24" />

            <!-- Default task planned hours -->
            <TextBlock Text="Default task planned time (hours)"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="When adding a new task, the planned time field will be pre-filled with this value. Leave empty to start with 0."
                       Foreground="#666666"
                       FontSize="12"
                       Margin="0,0,0,8" />
            <TextBox x:Name="DefaultTaskPlannedHoursBox"
                     Text="{Binding DefaultTaskPlannedHours, UpdateSourceTrigger=PropertyChanged}"
                     Width="160"
                     HorizontalAlignment="Left"
                     Padding="8,6"
                     FontSize="14"
                     BorderBrush="#CCCCCC"
                     BorderThickness="1"
                     Margin="0,0,0,32" />

            <!-- Floating timer -->
            <TextBlock Text="Floating timer window"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Show a compact always-on-top window while a timer is running."
                       Foreground="#666666"
                       FontSize="12"
                       Margin="0,0,0,8" />
            <CheckBox Content="Show floating timer"
                      IsChecked="{Binding ShowFloatingTimer}"
                      Margin="0,0,0,32" />

            <!-- Save button -->
            <Button Content="Save settings"
                    Width="140"
                    HorizontalAlignment="Left"
                    Padding="16,8"
                    Command="{Binding SaveCommand}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
