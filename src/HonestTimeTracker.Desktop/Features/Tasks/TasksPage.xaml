<UserControl x:Class="HonestTimeTracker.Desktop.Features.Tasks.TasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <TextBlock Text="Tasks" Style="{StaticResource HeaderText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
            <Button Content="+ Add task"
                    DockPanel.Dock="Right"
                    Padding="16,8"
                    Command="{Binding AddCommand}" />
        </DockPanel>

        <!-- Filter row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <CheckBox Content="Show closed tasks"
                      IsChecked="{Binding ShowClosed}"
                      VerticalAlignment="Center" />
        </StackPanel>

        <!-- Task list -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="TaskListView"
                      ItemsSource="{Binding Tasks}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>

                        <!-- Title -->
                        <GridViewColumn x:Name="TitleColumn" Header="Title" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Closed}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                        <Setter Property="Foreground" Value="#888888" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Project -->
                        <GridViewColumn Header="Project" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProjectName}" Foreground="#555555" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Planned time -->
                        <GridViewColumn Header="Plan (h)" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PlannedMinutes, Converter={StaticResource MinutesToHours}}" HorizontalAlignment="Right" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Spent time -->
                        <GridViewColumn Header="Spent (h)" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SpentMinutes, Converter={StaticResource MinutesToHours}}" HorizontalAlignment="Right" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Status -->
                        <GridViewColumn Header="Status" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Closed}" Value="True">
                                                        <Setter Property="Background" Value="#F5F5F5" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Text" Value="Active" />
                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Closed}" Value="True">
                                                            <Setter Property="Text" Value="Closed" />
                                                            <Setter Property="Foreground" Value="#757575" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Actions -->
                        <GridViewColumn Header="Actions" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <!-- Start timer (play) — zielony, widoczny gdy brak aktywnego timera -->
                                        <Button ToolTip="Start timer"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding HasActiveTimer, Converter={StaticResource InverseBoolToVisibility}}"
                                                Command="{Binding DataContext.StartTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonPrimary}">
                                                    <Setter Property="Background" Value="#2E7D32" />
                                                    <Setter Property="BorderBrush" Value="#2E7D32" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#1B5E20" />
                                                            <Setter Property="BorderBrush" Value="#1B5E20" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="White" Data="M5 3l14 9-14 9V3z"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Stop timer (square) — czerwony, widoczny gdy timer aktywny -->
                                        <Button Style="{StaticResource IconButtonDanger}"
                                                ToolTip="Stop timer"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding HasActiveTimer, Converter={StaticResource BoolToVisibility}}"
                                                Command="{Binding DataContext.StopTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Rectangle Canvas.Left="3" Canvas.Top="3" Width="18" Height="18" Fill="White" RadiusX="2" RadiusY="2"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Zamknij / Otwórz (check / rotate-ccw) — żółty -->
                                        <Button Margin="0,0,4,0"
                                                Command="{Binding DataContext.ToggleClosedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonPrimary}">
                                                    <Setter Property="ToolTip" Value="Close task" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Closed}" Value="True">
                                                            <Setter Property="ToolTip" Value="Reopen task" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="Black" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Visibility="{Binding Closed, Converter={StaticResource InverseBoolToVisibility}}"
                                                          Data="M20 6 9 17l-5-5"/>
                                                    <Path Stroke="Black" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Visibility="{Binding Closed, Converter={StaticResource BoolToVisibility}}"
                                                          Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                                                    <Path Stroke="Black" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Visibility="{Binding Closed, Converter={StaticResource BoolToVisibility}}"
                                                          Data="M3 3v5h5"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Trzy kropki — menu z edycją i usuwaniem -->
                                        <Button Style="{StaticResource IconButtonNeutral}"
                                                ToolTip="More actions"
                                                Click="MoreActions_Click"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Edit"
                                                              Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <Viewbox Width="14" Height="14">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                          Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                          Data="M15 5l4 4"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Delete"
                                                              Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                        <MenuItem.Icon>
                                                            <Viewbox Width="14" Height="14">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path Stroke="#CC0000" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                          Data="M3 6h18"/>
                                                                    <Path Stroke="#CC0000" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                          Data="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                                                    <Path Stroke="#CC0000" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                                          Data="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Ellipse Canvas.Left="11" Canvas.Top="4"  Width="2" Height="2" Fill="#444444"/>
                                                    <Ellipse Canvas.Left="11" Canvas.Top="11" Width="2" Height="2" Fill="#444444"/>
                                                    <Ellipse Canvas.Left="11" Canvas.Top="18" Width="2" Height="2" Fill="#444444"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
