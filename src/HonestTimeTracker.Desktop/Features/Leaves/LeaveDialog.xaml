<Window x:Class="HonestTimeTracker.Desktop.Features.Leaves.LeaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Leave"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Text="New leave"
                   Style="{StaticResource HeaderText}"
                   FontSize="18"
                   Margin="0,0,0,20" />

        <!-- Start date -->
        <TextBlock Grid.Row="1" Text="Start date" Margin="0,0,0,6" />
        <DatePicker Grid.Row="2"
                    x:Name="StartDatePicker"
                    Padding="6,4"
                    FontSize="14"
                    Margin="0,0,0,16"
                    SelectedDateChanged="DatePicker_SelectedDateChanged" />

        <!-- End date -->
        <TextBlock Grid.Row="3" Text="End date" Margin="0,0,0,6" />
        <DatePicker Grid.Row="4"
                    x:Name="EndDatePicker"
                    Padding="6,4"
                    FontSize="14"
                    Margin="0,0,0,16"
                    SelectedDateChanged="DatePicker_SelectedDateChanged" />

        <!-- Days count -->
        <TextBlock Grid.Row="5"
                   x:Name="DaysLabel"
                   Foreground="#A0522D"
                   FontSize="13"
                   Margin="0,0,0,16" />

        <!-- Description -->
        <TextBlock Grid.Row="6" Text="Description (optional)" Margin="0,0,0,6" />
        <TextBox Grid.Row="6"
                 x:Name="DescriptionBox"
                 Padding="8,6"
                 FontSize="14"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 Margin="0,24,0,20"
                 MaxLength="500" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Background="#E0E0E0"
                    Foreground="Black"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button x:Name="OkButton"
                    Content="Save"
                    Width="90"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
