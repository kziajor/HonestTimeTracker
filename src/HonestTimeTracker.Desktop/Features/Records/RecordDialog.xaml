<Window x:Class="HonestTimeTracker.Desktop.Features.Records.RecordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   x:Name="TitleText"
                   Text="New record"
                   Style="{StaticResource HeaderText}"
                   FontSize="18"
                   Margin="0,0,0,20" />

        <!-- Task -->
        <TextBlock Grid.Row="1" Text="Task" Margin="0,0,0,6" />
        <ComboBox Grid.Row="2"
                  x:Name="TaskComboBox"
                  Padding="8,6"
                  FontSize="14"
                  BorderBrush="#CCCCCC"
                  BorderThickness="1"
                  Margin="0,0,0,16"
                  DisplayMemberPath="Title"
                  SelectedValuePath="Id" />

        <!-- Date -->
        <TextBlock Grid.Row="3" Text="Date" Margin="0,0,0,6" />
        <DatePicker Grid.Row="4"
                    x:Name="DatePicker"
                    FontSize="14"
                    Margin="0,0,0,16" />

        <!-- Time row -->
        <Grid Grid.Row="5" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Start time (HH:mm)" Margin="0,0,0,6" />
                <TextBox x:Name="StartTimeBox"
                         Padding="8,6"
                         FontSize="14"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         MaxLength="5" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="End time (HH:mm)" Margin="0,0,0,6" />
                <TextBox x:Name="EndTimeBox"
                         Padding="8,6"
                         FontSize="14"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         MaxLength="5" />
                <TextBlock x:Name="EndTimeHint"
                           Text="Leave empty to start a running record"
                           FontSize="11"
                           Foreground="#888888"
                           Margin="0,4,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <!-- Comment -->
        <TextBlock Grid.Row="6" Text="Comment (optional)" Margin="0,0,0,6" />
        <TextBox Grid.Row="7"
                 x:Name="CommentBox"
                 Padding="8,6"
                 FontSize="14"
                 BorderBrush="#CCCCCC"
                 BorderThickness="1"
                 Margin="0,0,0,20"
                 TextWrapping="Wrap"
                 AcceptsReturn="False"
                 MaxLength="1000" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="90"
                    Background="#E0E0E0"
                    Foreground="Black"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button x:Name="OkButton"
                    Content="Save"
                    MinWidth="110"
                    Padding="16,8"
                    Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
