<UserControl x:Class="HonestTimeTracker.Desktop.Features.Records.RecordsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <TextBlock Text="Records" Style="{StaticResource HeaderText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
            <Button Content="+ Add record"
                    DockPanel.Dock="Right"
                    Padding="16,8"
                    Command="{Binding AddCommand}" />
        </DockPanel>

        <!-- Filter row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <CheckBox Content="Filter by date"
                      IsChecked="{Binding FilterByDate}"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0" />
            <DatePicker x:Name="FilterDatePicker"
                        SelectedDate="{Binding FilterDate, Converter={StaticResource DateOnlyConverter}}"
                        IsEnabled="{Binding FilterByDate}"
                        FontSize="13"
                        VerticalAlignment="Center" />
        </StackPanel>

        <!-- Active record banner -->
        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Padding="14,10"
                Background="#1a1a1a"
                CornerRadius="4"
                Visibility="{Binding HasActiveRecord, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">

                    <!-- Edit active record -->
                    <Button Style="{StaticResource IconButtonNeutral}"
                            ToolTip="Edit record"
                            Margin="0,0,6,0"
                            Command="{Binding EditCommand}"
                            CommandParameter="{Binding ActiveRecord}">
                        <Viewbox Width="15" Height="15">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                      Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                                <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                      Data="M15 5l4 4"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Stop active record -->
                    <Button Style="{StaticResource IconButtonDanger}"
                            ToolTip="Stop timer"
                            Command="{Binding StopTimerCommand}">
                        <Viewbox Width="15" Height="15">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="3" Canvas.Top="3" Width="18" Height="18" Fill="White" RadiusX="2" RadiusY="2"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                </StackPanel>

                <!-- Pulsing indicator -->
                <Ellipse Width="10" Height="10" Fill="#e74c3c" DockPanel.Dock="Left"
                         VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.8" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <!-- Task / project -->
                <StackPanel DockPanel.Dock="Left" Margin="0,0,28,0">
                    <TextBlock Text="Now tracking" FontSize="10" Foreground="#888888" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ActiveTaskTitle}" FontSize="14" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="{Binding ActiveProjectName, StringFormat=' · {0}'}"
                                   FontSize="14" Foreground="#aaaaaa"
                                   Visibility="{Binding ActiveProjectName, Converter={StaticResource NullOrEmptyToVisibility}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Start time -->
                <StackPanel DockPanel.Dock="Left" Margin="0,0,28,0">
                    <TextBlock Text="Started" FontSize="10" Foreground="#888888" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ActiveStartTime}" FontSize="14" FontWeight="Bold" Foreground="White" />
                </StackPanel>

                <!-- Elapsed -->
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Elapsed" FontSize="10" Foreground="#888888" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ActiveElapsed}" FontSize="14" FontWeight="Bold" Foreground="#fbcb18" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Summary bar -->
        <Border Grid.Row="3"
                Margin="0,0,0,12"
                Padding="14,10"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="4"
                Visibility="{Binding HasSummary, Converter={StaticResource BoolToVisibility}}">
            <StackPanel Orientation="Horizontal">

                <!-- Actual -->
                <StackPanel Margin="0,0,28,0">
                    <TextBlock Text="Actual" FontSize="11" Foreground="#7a6000" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SummaryActual}" FontSize="16" FontWeight="Bold" />
                </StackPanel>

                <!-- Required -->
                <StackPanel Margin="0,0,28,0">
                    <TextBlock Text="Required" FontSize="11" Foreground="#7a6000" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SummaryRequired}" FontSize="16" FontWeight="Bold" />
                </StackPanel>

                <!-- Balance -->
                <StackPanel Margin="0,0,28,0">
                    <TextBlock FontSize="11" Foreground="#7a6000" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Deficit" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SummaryIsPositive}" Value="True">
                                        <Setter Property="Text" Value="Overtime" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding SummaryBalance}" FontSize="16" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#c0392b" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SummaryIsPositive}" Value="True">
                                        <Setter Property="Foreground" Value="#1e8449" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Working days context -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding SummaryWorkingDays}"
                               FontSize="12"
                               Foreground="#7a6000" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Records list -->
        <Border Grid.Row="4" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="RecordsListView"
                      ItemsSource="{Binding Records}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>

                        <!-- Date -->
                        <GridViewColumn Header="Date" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartedAt, StringFormat=\{0:yyyy-MM-dd\}}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Time range -->
                        <GridViewColumn Header="Time" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding StartedAt, StringFormat=\{0:HH:mm\}}" />
                                        <Run Text="–" />
                                        <Run Text="{Binding FinishedAt, StringFormat=\{0:HH:mm\}, TargetNullValue=running}" />
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Duration -->
                        <GridViewColumn Header="Duration (h)" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MinutesSpent, Converter={StaticResource MinutesToHours}}" HorizontalAlignment="Right" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Task -->
                        <GridViewColumn x:Name="TaskColumn" Header="Task" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TaskTitle}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Project -->
                        <GridViewColumn Header="Project" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProjectName}" Foreground="#555555" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Comment -->
                        <GridViewColumn Header="Comment" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Comment}" Foreground="#555555"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Actions -->
                        <GridViewColumn Header="Actions" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <!-- Delete -->
                                        <Button Style="{StaticResource IconButtonDanger}"
                                                ToolTip="Delete record"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M3 6h18"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M10 11v6"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M14 11v6"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Stop — visible only for running records -->
                                        <Button Style="{StaticResource IconButtonDanger}"
                                                ToolTip="Stop timer"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding FinishedAt, Converter={StaticResource NullToVisibility}}"
                                                Command="{Binding DataContext.StopTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Rectangle Canvas.Left="3" Canvas.Top="3" Width="18" Height="18" Fill="White" RadiusX="2" RadiusY="2"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Edit -->
                                        <Button Style="{StaticResource IconButtonNeutral}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M15 5l4 4"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
