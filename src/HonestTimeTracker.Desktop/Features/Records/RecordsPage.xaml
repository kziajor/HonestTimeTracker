<UserControl x:Class="HonestTimeTracker.Desktop.Features.Records.RecordsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16" LastChildFill="False">
            <TextBlock Text="Records" Style="{StaticResource HeaderText}" DockPanel.Dock="Left" VerticalAlignment="Center" />
            <Button Content="+ Add record"
                    DockPanel.Dock="Right"
                    Padding="16,8"
                    Command="{Binding AddCommand}" />
        </DockPanel>

        <!-- Filter row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <CheckBox Content="Filter by date"
                      IsChecked="{Binding FilterByDate}"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0" />
            <DatePicker x:Name="FilterDatePicker"
                        SelectedDate="{Binding FilterDate, Converter={StaticResource DateOnlyConverter}}"
                        IsEnabled="{Binding FilterByDate}"
                        FontSize="13"
                        VerticalAlignment="Center" />
        </StackPanel>

        <!-- Records list -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="RecordsListView"
                      ItemsSource="{Binding Records}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>

                        <!-- Date -->
                        <GridViewColumn Header="Date" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartedAt, StringFormat=\{0:yyyy-MM-dd\}}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Time range -->
                        <GridViewColumn Header="Time" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding StartedAt, StringFormat=\{0:HH:mm\}}" />
                                        <Run Text="–" />
                                        <Run Text="{Binding FinishedAt, StringFormat=\{0:HH:mm\}}" />
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Duration -->
                        <GridViewColumn Header="Duration (min)" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MinutesSpent}" HorizontalAlignment="Right" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Task -->
                        <GridViewColumn x:Name="TaskColumn" Header="Task" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TaskTitle}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Project -->
                        <GridViewColumn Header="Project" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProjectName}" Foreground="#555555" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Comment -->
                        <GridViewColumn Header="Comment" Width="160">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Comment}" Foreground="#555555"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Actions -->
                        <GridViewColumn Header="Actions" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">

                                        <!-- Delete -->
                                        <Button Style="{StaticResource IconButtonDanger}"
                                                ToolTip="Delete record"
                                                Margin="0,0,4,0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M3 6h18"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M10 11v6"/>
                                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M14 11v6"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                        <!-- Edit -->
                                        <Button Style="{StaticResource IconButtonNeutral}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Viewbox Width="15" Height="15">
                                                <Canvas Width="24" Height="24">
                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                                                    <Path Stroke="#444444" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"
                                                          Data="M15 5l4 4"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Button>

                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</UserControl>
